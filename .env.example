# Local Postgres (docker compose up -d db). OWNER connection — used by
# migrations, seed/cron scripts, the Stripe webhook, and org-bootstrap
# queries (src/lib/tenancy.ts). Bypasses row-level security: see
# src/lib/db/index.ts (dbSystem) and README > Deployment notes.
DATABASE_URL=postgres://agropeq:agropeq@localhost:5433/agropeq

# RLS-bound application role (agropeq_app, created by
# drizzle/0017_app-role.sql). Password lives only here — never in a
# migration file. Must satisfy /^[A-Za-z0-9_-]{8,}$/ (see
# src/scripts/set-app-password.ts). After changing it, run
# `pnpm db:set-app-password` to apply it to the DB role, then update
# APP_DATABASE_URL below to match.
APP_DB_PASSWORD=
# Request-scoped connection used by the app (src/lib/db/index.ts `db`).
# Every query on this connection is subject to RLS policies (drizzle/0018).
# Falls back to DATABASE_URL (and logs a loud warning) if unset, which is
# fine for a throwaway local DB but should never happen in production.
APP_DATABASE_URL=postgres://agropeq_app:agropeq_app_dev@localhost:5433/agropeq

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (optional — billing UI degrades gracefully without it)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SEMILLA=
STRIPE_PRICE_CULTIVO=
STRIPE_PRICE_COSECHA=

# SMTP email (optional — degrades gracefully: with EMAIL_SMTP_HOST,
# EMAIL_SMTP_PORT and EMAIL_FROM all unset, src/lib/email/index.ts falls
# back to a console-logger adapter, so invites and the daily digest
# (pnpm digest:send) still run — they just log instead of sending).
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_FROM=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SECURE=
