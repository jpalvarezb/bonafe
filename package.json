{
  "name": "agropeq",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env src/scripts/seed.ts",
    "db:set-app-password": "tsx --env-file=.env src/scripts/set-app-password.ts",
    "db:verify-rls": "tsx --env-file=.env src/scripts/verify-rls.ts",
    "climate:ingest": "tsx --env-file=.env src/scripts/ingest-climate.ts",
    "fx:ingest": "tsx --env-file=.env src/scripts/ingest-exchange-rates.ts",
    "digest:send": "tsx --env-file=.env src/scripts/send-digest.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@serwist/next": "^9.5.11",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.9.2",
    "serwist": "^9.5.11",
    "shadcn": "^4.13.0",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "terra-draw": "^1.31.2",
    "terra-draw-maplibre-gl-adapter": "^1.4.1",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "wkx": "^0.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
